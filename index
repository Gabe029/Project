    function cancelEdit() {
        editMode = false;
        editId = null;
        document.getElementById('editMode').value = 'false';
        document.getElementById('editId').value = '';
        document.getElementById('editModeIndicator').style.display = 'none';
        document.getElementById('cancelEditBtn').style.display = 'none';
        resetAdminForm();
        showToast('✏️ Edit cancelled', 'warning');
    }

    function saveProduct() {
        const name = document.getElementById('adminName').value.trim();
        const category = document.getElementById('adminCategory').value;
        const icon = document.getElementById('adminIcon').value.trim();
        const desc = document.getElementById('adminDesc').value.trim();
        const price = parseInt(document.getElementById('adminPrice').value);
        const discount = parseInt(document.getElementById('adminDiscount').value) || 0;
        const status = document.getElementById('adminStatus').value;
        const featured = document.getElementById('adminFeatured').value === 'true';
        const platform = document.getElementById('adminPlatform').value.trim();
        const version = document.getElementById('adminVersion').value.trim();

        if (!name || !price) {
            showToast('⚠️ Please fill in the software name and price.', 'error');
            return;
        }

        if (price < 0) {
            showToast('⚠️ Price must be a positive number.', 'error');
            return;
        }

        if (editMode && editId) {
            // UPDATE existing product
            const index = products.findIndex(p => p.id === editId);
            if (index !== -1) {
                const oldProduct = products[index];
                products[index] = {
                    ...oldProduct,
                    name,
                    category,
                    icon: icon || 'fa-solid fa-software',
                    description: desc || 'No description provided.',
                    price: price,
                    discount: discount,
                    status,
                    featured,
                    platform: platform || 'Windows / 8GB RAM / 100GB storage',
                    version: version || 'v1.0',
                    fileName: selectedFile ? selectedFile.name : oldProduct.fileName,
                    fileSize: selectedFile ? (selectedFile.size / 1024 / 1024).toFixed(1) + ' MB' : oldProduct.fileSize,
                    fileData: selectedFile ? URL.createObjectURL(selectedFile) : oldProduct.fileData,
                    updatedAt: new Date().toISOString()
                };
                
                showToast(`✅ "${name}" updated successfully!`, 'success');
                editMode = false;
                editId = null;
                document.getElementById('editMode').value = 'false';
                document.getElementById('editId').value = '';
                document.getElementById('editModeIndicator').style.display = 'none';
                document.getElementById('cancelEditBtn').style.display = 'none';
            }
        } else {
            // ADD new product
            const newProduct = {
                id: nextId++,
                name,
                category,
                icon: icon || 'fa-solid fa-software',
                description: desc || 'No description provided.',
                price: price,
                discount: discount,
                status,
                featured,
                platform: platform || 'Windows / 8GB RAM / 100GB storage',
                version: version || 'v1.0',
                fileName: selectedFile ? selectedFile.name : null,
                fileSize: selectedFile ? (selectedFile.size / 1024 / 1024).toFixed(1) + ' MB' : null,
                fileData: selectedFile ? URL.createObjectURL(selectedFile) : null,
                sales: 0,
                ownerId: 'owner',
                createdAt: new Date().toISOString(),
                purchasedBy: []
            };

            products.push(newProduct);
            showToast(`✅ "${name}" added! (KES ${formatKES(price)})`);
        }

        renderProducts(products);
        resetAdminForm();
        
        if (selectedFile) {
            selectedFile = null;
            document.getElementById('filePreview').classList.remove('show');
        }
        
        saveToStorage();
    }

    function resetAdminForm() {
        document.getElementById('adminName').value = '';
        document.getElementById('adminDesc').value = '';
        document.getElementById('adminPrice').value = '';
        document.getElementById('adminDiscount').value = '';
        document.getElementById('adminPlatform').value = '';
        document.getElementById('adminVersion').value = '';
        document.getElementById('adminIcon').value = 'fa-solid fa-database';
        document.getElementById('adminStatus').value = 'in-stock';
        document.getElementById('adminFeatured').value = 'false';
        document.getElementById('adminFile').value = '';
        document.getElementById('filePreview').classList.remove('show');
        selectedFile = null;
        
        if (!editMode) {
            document.getElementById('editMode').value = 'false';
            document.getElementById('editId').value = '';
            document.getElementById('editModeIndicator').style.display = 'none';
            document.getElementById('cancelEditBtn').style.display = 'none';
        }
    }

    // ----- DELETE (Owner Only) -----
    function openDeleteModal(id) {
        if (!isOwner) {
            if (!authenticateOwner()) {
                return;
            }
        }
        
        deleteTargetId = id;
        const product = products.find(p => p.id === id);
        if (product) {
            document.getElementById('deleteMessage').textContent = 
                `Are you sure you want to delete "${product.name}" (KES ${formatKES(product.price)})? This action cannot be undone.`;
        }
        document.getElementById('deleteModal').classList.add('show');
        document.getElementById('confirmDeleteBtn').onclick = function() {
            confirmDelete();
        };
    }

    function closeDeleteModal() {
        document.getElementById('deleteModal').classList.remove('show');
        deleteTargetId = null;
    }

    function confirmDelete() {
        if (deleteTargetId === null) return;
        
        if (!isOwner) {
            showToast('❌ Only the owner can delete software!', 'error');
            closeDeleteModal();
            return;
        }
        
        const index = products.findIndex(p => p.id === deleteTargetId);
        if (index !== -1) {
            const deleted = products[index];
            if (deleted.fileData) {
                URL.revokeObjectURL(deleted.fileData);
            }
            products.splice(index, 1);
            renderProducts(products);
            showToast(`🗑️ "${deleted.name}" deleted successfully`, 'success');
            saveToStorage();
        }
        
        closeDeleteModal();
    }

    document.getElementById('deleteModal').addEventListener('click', function(e) {
        if (e.target === this) closeDeleteModal();
    });

    // ----- EXPORT / IMPORT DATA -----
    function exportData() {
        const data = products.map(p => {
            const { fileData, ...rest } = p;
            return rest;
        });
        const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `audem-kasten-software-backup-${new Date().toISOString().split('T')[0]}.json`;
        a.click();
        URL.revokeObjectURL(url);
        showToast('📥 Data exported successfully!', 'success');
    }

    function importData(event) {
        const file = event.target.files[0];
        if (!file) return;
        
        const reader = new FileReader();
        reader.onload = function(e) {
            try {
                const imported = JSON.parse(e.target.result);
                if (Array.isArray(imported) && imported.length > 0) {
                    if (confirm(`⚠️ This will replace ALL current data with ${imported.length} products. Continue?`)) {
                        products = imported.map(p => ({
                            ...p,
                            fileData: null,
                            ownerId: 'owner',
                            purchasedBy: p.purchasedBy || []
                        }));
                        nextId = Math.max(...products.map(p => p.id)) + 1;
                        renderProducts(products);
                        saveToStorage();
                        showToast(`📥 Imported ${products.length} products successfully!`, 'success');
                    }
                } else {
                    showToast('❌ Invalid data format.', 'error');
                }
            } catch (err) {
                showToast('❌ Error reading file.', 'error');
            }
        };
        reader.readAsText(file);
        event.target.value = '';
    }

    // ----- LOCAL STORAGE -----
    function saveToStorage() {
        try {
            const saveData = products.map(p => {
                const { fileData, ...rest } = p;
                return rest;
            });
            localStorage.setItem('audemKastenProducts', JSON.stringify(saveData));
        } catch (e) {
            console.log('Could not save');
        }
    }

    function loadFromStorage() {
        try {
            const saved = localStorage.getItem('audemKastenProducts');
            if (saved) {
                const parsed = JSON.parse(saved);
                if (Array.isArray(parsed) && parsed.length > 0) {
                    products = parsed.map(p => ({
                        ...p,
                        ownerId: p.ownerId || 'owner',
                        purchasedBy: p.purchasedBy || []
                    }));
                    nextId = Math.max(...products.map(p => p.id)) + 1;
                    renderProducts(products);
                }
            }
        } catch (e) {
            console.log('No saved data');
        }
    }

    // ----- KEYBOARD SHORTCUTS -----
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            if (document.getElementById('adminPanel').classList.contains('show')) {
                toggleAdmin();
            }
            if (document.getElementById('cartSidebar').classList.contains('show')) {
                toggleCart();
            }
            if (document.getElementById('deleteModal').classList.contains('show')) {
                closeDeleteModal();
            }
            if (editMode) {
                cancelEdit();
            }
        }
        if (e.ctrlKey && e.key === 's') {
            e.preventDefault();
            if (document.getElementById('adminPanel').classList.contains('show')) {
                saveProduct();
            }
        }
    });

    // ----- INIT -----
    loadCustomerPurchases();
    loadFromStorage();
</script>

</body>
</html>
