    // ----- EDIT FUNCTIONALITY -----
    function openEditModal(id) {
        if (!isOwner) {
            authenticateOwner();
            return;
        }
        
        const product = products.find(p => p.id === id);
        if (!product) return;
        
        editMode = true;
        editId = id;
        
        document.getElementById('editMode').value = 'true';
        document.getElementById('editId').value = id;
