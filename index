<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Audem Kasten Technology's · Premium Software Store</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f0f4fc;
            color: #0b1a2f;
            min-height: 100vh;
        }

        .brand-logo-wrapper {
            position: relative;
            width: 72px;
            height: 72px;
            flex-shrink: 0;
            background: linear-gradient(135deg, #1a73e8 0%, #0d47a1 100%);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 6px 24px rgba(26, 115, 232, 0.4);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            overflow: hidden;
        }

        .brand-logo-wrapper:hover {
            transform: scale(1.08) rotate(-2deg);
            box-shadow: 0 8px 32px rgba(26, 115, 232, 0.5);
        }

        .brand-logo-wrapper svg {
            width: 58px;
            height: 58px;
            filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.2));
        }

        .brand-logo-wrapper .logo-badge {
            position: absolute;
            bottom: -6px;
            right: -6px;
            background: linear-gradient(135deg, #fbbc04, #ea4335);
            color: white;
            font-size: 0.45rem;
            font-weight: 800;
            padding: 0.15rem 0.4rem;
            border-radius: 40px;
            border: 2px solid white;
            letter-spacing: 0.03em;
        }

        .scroll-top {
            position: fixed;
            bottom: 2rem;
            left: 2rem;
            background: #1a73e8;
            color: white;
            border: none;
            width: 48px;
            height: 48px;
            border-radius: 60px;
            font-size: 1.2rem;
            cursor: pointer;
            box-shadow: 0 4px 16px rgba(26, 115, 232, 0.3);
            transition: 0.3s;
            z-index: 50;
            display: none;
            align-items: center;
            justify-content: center;
        }

        .scroll-top:hover {
            transform: scale(1.1);
            background: #1557b0;
        }

        .scroll-top.show {
            display: flex;
        }

        .top-bar {
            background: white;
            padding: 1rem 2rem;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 1.2rem;
        }

        .brand .brand-text h1 {
            font-size: 1.8rem;
            font-weight: 700;
            color: #0b1a2f;
        }
        .brand .brand-text h1 .highlight { color: #1a73e8; }
        .brand .brand-text .sub {
            font-size: 0.75rem;
            color: #5a6b8a;
            font-weight: 400;
            display: block;
            letter-spacing: 0.05em;
        }

        .currency-badge {
            background: #e8f0fe;
            color: #1a73e8;
            padding: 0.3rem 1rem;
            border-radius: 60px;
            font-weight: 600;
            font-size: 0.8rem;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }

        .top-actions {
            display: flex;
            gap: 1rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .btn-admin {
            background: #1a73e8;
            color: white;
            border: none;
            padding: 0.5rem 1.4rem;
            border-radius: 60px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-admin:hover {
            background: #1557b0;
            transform: scale(1.02);
        }

        .btn-admin.owner-mode {
            background: #34a853;
        }

        .btn-cart {
            background: #f1f3f4;
            border: none;
            padding: 0.5rem 1.4rem;
            border-radius: 60px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: 0.2s;
        }

        .btn-cart:hover {
            background: #e8eaed;
        }

        .badge-count {
            background: #ea4335;
            color: white;
            border-radius: 60px;
            padding: 0.1rem 0.6rem;
            font-size: 0.75rem;
        }

        .hero {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 2rem;
            text-align: center;
        }

        .hero h2 {
            font-size: 2.8rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            margin-bottom: 0.5rem;
        }

        .hero h2 i { color: #1a73e8; }
        .hero h2 .brand-name { color: #1a73e8; }

        .hero p {
            color: #4a5b7a;
            font-size: 1.2rem;
            max-width: 600px;
            margin: 0 auto 1.5rem;
        }

        .hero .tag {
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            background: #e8f0fe;
            padding: 0.4rem 1.4rem;
            border-radius: 60px;
            color: #1a73e8;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem 3rem;
        }

        .filter-bar {
            display: flex;
            flex-wrap: wrap;
            gap: 0.8rem;
            margin: 2rem 0 1.5rem;
            align-items: center;
        }

        .filter-bar input {
            flex: 1;
            min-width: 200px;
            padding: 0.7rem 1.2rem;
            border: 1px solid #dde3ed;
            border-radius: 60px;
            font-size: 0.95rem;
            background: white;
        }

        .filter-bar input:focus {
            outline: none;
            border-color: #1a73e8;
        }

        .filter-bar select {
            padding: 0.7rem 1.2rem;
            border: 1px solid #dde3ed;
            border-radius: 60px;
            font-size: 0.95rem;
            background: white;
            cursor: pointer;
        }

        .filter-bar .results {
            color: #5a6b8a;
            font-size: 0.9rem;
            margin-left: auto;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 2rem;
        }

        .card {
            background: white;
            border-radius: 24px;
            padding: 1.8rem;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
            transition: all 0.25s ease;
            border: 1px solid #edf2f9;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 32px rgba(26, 115, 232, 0.08);
            border-color: #d2e0f5;
        }

        .card .icon {
            font-size: 2.6rem;
            color: #1a73e8;
            background: #e8f0fe;
            width: 68px;
            height: 68px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
        }

        .card .category {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 600;
            color: #1a73e8;
            background: #e8f0fe;
            padding: 0.2rem 0.8rem;
            border-radius: 40px;
            align-self: flex-start;
            margin-bottom: 0.5rem;
        }

        .card h3 {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 0.3rem;
        }

        .card .desc {
            color: #4a5b7a;
            font-size: 0.95rem;
            margin: 0.3rem 0 1rem;
            flex: 1;
            line-height: 1.5;
        }

        .card .specs {
            display: flex;
            gap: 1rem;
            font-size: 0.8rem;
            color: #5a6b8a;
            margin-bottom: 1.2rem;
            flex-wrap: wrap;
        }

        .card .specs i { color: #1a73e8; margin-right: 0.2rem; }

        .card .price-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-top: 0.5rem;
        }

        .card .price {
            font-size: 1.8rem;
            font-weight: 700;
            color: #0b1a2f;
        }

        .card .price .kes {
            font-size: 1rem;
            font-weight: 600;
            color: #1a73e8;
            margin-right: 0.2rem;
        }

        .card .price small {
            font-size: 0.9rem;
            font-weight: 400;
            color: #6a7b9a;
        }

        .card .btn-buy {
            background: linear-gradient(135deg, #1a73e8, #0d47a1);
            color: white;
            border: none;
            padding: 0.6rem 1.6rem;
            border-radius: 60px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            box-shadow: 0 4px 12px rgba(26, 115, 232, 0.25);
        }

        .card .btn-buy:hover {
            transform: scale(1.05);
            box-shadow: 0 6px 20px rgba(26, 115, 232, 0.4);
        }

        .card .btn-buy.out-of-stock {
            background: #dadce0;
            cursor: not-allowed;
            opacity: 0.7;
            box-shadow: none;
        }

        .card .btn-buy.out-of-stock:hover {
            transform: none;
            box-shadow: none;
        }

        .card .purchased-badge {
            display: inline-block;
            background: #34a853;
            color: white;
            padding: 0.2rem 0.8rem;
            border-radius: 40px;
            font-size: 0.65rem;
            font-weight: 700;
            margin-top: 0.3rem;
        }

        .card .platform-tag {
            font-size: 0.7rem;
            color: #1a73e8;
            background: #e8f0fe;
            padding: 0.15rem 0.7rem;
            border-radius: 40px;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            margin-top: 0.3rem;
        }

        .card .file-tag {
            font-size: 0.7rem;
            color: #34a853;
            background: #e6f4ea;
            padding: 0.15rem 0.7rem;
            border-radius: 40px;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            margin-top: 0.3rem;
        }

        .card .discount-badge {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: #ea4335;
            color: white;
            padding: 0.2rem 0.8rem;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 700;
        }

        .card .featured-badge {
            position: absolute;
            top: 1rem;
            left: 1rem;
            background: #fbbc04;
            color: #0b1a2f;
            padding: 0.2rem 0.8rem;
            border-radius: 40px;
            font-size: 0.6rem;
            font-weight: 700;
            text-transform: uppercase;
        }

        .admin-panel {
            display: none;
            background: white;
            border-radius: 28px;
            padding: 2rem;
            margin-top: 2rem;
            border: 1px solid #edf2f9;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
        }

        .admin-panel.show {
            display: block;
        }

        .admin-panel h3 {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            font-size: 1.4rem;
            margin-bottom: 1.5rem;
        }

        .admin-panel h3 i { color: #1a73e8; }

        .admin-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
        }

        .admin-form-group {
            margin-bottom: 1.2rem;
        }

        .admin-form-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.3rem;
            font-size: 0.9rem;
        }

        .admin-form-group input,
        .admin-form-group select,
        .admin-form-group textarea {
            width: 100%;
            padding: 0.7rem 1rem;
            border: 1px solid #dde3ed;
            border-radius: 12px;
            font-size: 0.95rem;
            background: #fafbfc;
        }

        .admin-form-group input:focus,
        .admin-form-group textarea:focus {
            outline: none;
            border-color: #1a73e8;
        }

        .admin-form-group textarea {
            resize: vertical;
            min-height: 60px;
        }

        .admin-form-group input[type="file"] {
            padding: 0.5rem;
            background: white;
        }

        .admin-form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .btn-save {
            background: #34a853;
            color: white;
            border: none;
            padding: 0.7rem 2rem;
            border-radius: 60px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-save:hover {
            background: #2d9248;
            transform: scale(1.02);
        }

        .btn-danger {
            background: #ea4335;
            color: white;
            border: none;
            padding: 0.7rem 2rem;
            border-radius: 60px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-danger:hover {
            background: #d33426;
            transform: scale(1.02);
        }

        .btn-secondary {
            background: #f1f3f4;
            color: #3c4043;
            border: none;
            padding: 0.7rem 2rem;
            border-radius: 60px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-secondary:hover {
            background: #e8eaed;
            transform: scale(1.02);
        }

        .admin-actions {
            display: flex;
            gap: 1rem;
            margin-top: 1rem;
            flex-wrap: wrap;
        }

        .cart-sidebar {
            display: none;
            position: fixed;
            right: 0;
            top: 0;
            bottom: 0;
            width: 380px;
            background: white;
            box-shadow: -4px 0 24px rgba(0, 0, 0, 0.08);
            padding: 2rem;
            z-index: 200;
            overflow-y: auto;
        }

        .cart-sidebar.show {
            display: block;
        }

        .cart-sidebar .close {
            float: right;
            font-size: 1.5rem;
            cursor: pointer;
            color: #5a6b8a;
        }

        .cart-sidebar h3 {
            margin-bottom: 1.5rem;
            font-size: 1.4rem;
        }

        .cart-item {
            display: flex;
            justify-content: space-between;
            padding: 0.8rem 0;
            border-bottom: 1px solid #edf2f9;
        }

        .cart-item .remove-item {
            color: #ea4335;
            cursor: pointer;
            margin-left: 0.5rem;
        }

        .cart-total {
            font-weight: 700;
            font-size: 1.2rem;
            margin-top: 1.5rem;
            text-align: right;
        }

        .cart-total .kes {
            color: #1a73e8;
        }

        .btn-checkout {
            background: #34a853;
            color: white;
            border: none;
            padding: 0.8rem 2rem;
            border-radius: 60px;
            font-weight: 600;
            width: 100%;
            margin-top: 1rem;
            cursor: pointer;
            transition: 0.2s;
        }

        .btn-checkout:hover {
            background: #2d9248;
            transform: scale(1.02);
        }

        .btn-clear-cart {
            background: #ea4335;
            color: white;
            border: none;
            padding: 0.6rem 1rem;
            border-radius: 60px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            margin-top: 0.5rem;
            font-size: 0.8rem;
        }

        .btn-clear-cart:hover {
            background: #d33426;
            transform: scale(1.02);
        }

        .overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.3);
            z-index: 150;
        }

        .overlay.show {
            display: block;
        }

        .delete-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            z-index: 300;
            justify-content: center;
            align-items: center;
        }

        .delete-modal.show {
            display: flex;
        }

        .delete-modal-content {
            background: white;
            border-radius: 28px;
            padding: 2.5rem;
            max-width: 420px;
            width: 90%;
            text-align: center;
        }

        .delete-modal-content i {
            font-size: 3rem;
            color: #ea4335;
            margin-bottom: 1rem;
        }

        .delete-modal-content h3 {
            margin-bottom: 0.5rem;
        }

        .delete-modal-content p {
            color: #5a6b8a;
            margin-bottom: 1.5rem;
        }

        .delete-modal-actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
        }

        .file-preview {
            background: #f8f9fa;
            border: 1px dashed #dde3ed;
            border-radius: 12px;
            padding: 0.8rem;
            margin-top: 0.5rem;
            display: none;
            align-items: center;
            gap: 0.8rem;
        }

        .file-preview.show {
            display: flex;
        }

        .file-preview i {
            color: #34a853;
            font-size: 1.5rem;
        }

        .file-preview .file-info {
            flex: 1;
        }

        .file-preview .file-info .name {
            font-weight: 600;
            font-size: 0.9rem;
        }

        .file-preview .file-info .size {
            color: #5a6b8a;
            font-size: 0.8rem;
        }

        .file-preview .remove-file {
            color: #ea4335;
            cursor: pointer;
            font-size: 1.2rem;
        }

        .toast {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: #0b1a2f;
            color: white;
            padding: 1rem 1.5rem;
            border-radius: 16px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
            z-index: 500;
            display: none;
            max-width: 350px;
            animation: slideUp 0.3s ease;
        }

        .toast.show {
            display: block;
        }

        .toast.success {
            border-left: 4px solid #34a853;
        }

        .toast.error {
            border-left: 4px solid #ea4335;
        }

        .toast.warning {
            border-left: 4px solid #fbbc04;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .empty-state {
            grid-column: 1/-1;
            text-align: center;
            padding: 3rem;
            color: #5a6b8a;
        }

        .empty-state i {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
            color: #dde3ed;
        }

        .stats-bar {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .stat-item {
            background: white;
            padding: 1rem;
            border-radius: 16px;
            text-align: center;
            border: 1px solid #edf2f9;
            transition: 0.2s;
        }

        .stat-item:hover {
            border-color: #1a73e8;
            box-shadow: 0 4px 12px rgba(26, 115, 232, 0.06);
        }

        .stat-item .number {
            font-size: 1.8rem;
            font-weight: 700;
            color: #1a73e8;
        }

        .stat-item .label {
            font-size: 0.8rem;
            color: #5a6b8a;
        }

        .footer {
            text-align: center;
            padding: 2rem;
            color: #5a6b8a;
            font-size: 0.9rem;
            border-top: 1px solid #edf2f9;
            margin-top: 2rem;
        }

        .footer .brand-name {
            color: #1a73e8;
            font-weight: 600;
        }

        .footer .social-links {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            margin-top: 1rem;
        }

        .footer .social-links a {
            color: #5a6b8a;
            font-size: 1.2rem;
            transition: 0.2s;
        }

        .footer .social-links a:hover {
            color: #1a73e8;
            transform: translateY(-2px);
        }

        .whatsapp-float {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            z-index: 100;
            animation: pulse 2s infinite;
        }

        .whatsapp-float a {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 60px;
            height: 60px;
            background: #25d366;
            color: white;
            border-radius: 50%;
            font-size: 2rem;
            box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4);
            transition: 0.3s;
            text-decoration: none;
        }

        .whatsapp-float a:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 30px rgba(37, 211, 102, 0.5);
        }

        .download-history {
            margin-top: 1rem;
            padding: 1rem;
            background: #f8f9fa;
            border-radius: 12px;
            border: 1px solid #edf2f9;
        }

        .download-history h4 {
            font-size: 0.8rem;
            color: #5a6b8a;
            margin-bottom: 0.5rem;
        }

        .download-history .history-item {
            display: flex;
            justify-content: space-between;
            padding: 0.3rem 0;
            font-size: 0.8rem;
            border-bottom: 1px solid #edf2f9;
        }

        .download-history .history-item:last-child {
            border-bottom: none;
        }

        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }

        @media (max-width: 768px) {
            .admin-grid {
                grid-template-columns: 1fr;
            }
            .admin-form-row {
                grid-template-columns: 1fr;
            }
            .hero h2 {
