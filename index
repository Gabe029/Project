        } else if (password !== null) {
            showToast('❌ Incorrect password. Access denied.', 'error');
            return false;
        }
        return false;
    }

    // ----- WHATSAPP CONTACT FUNCTION -----
    function contactWhatsApp(message) {
        const encoded = encodeURIComponent(message);
        window.open(`https://wa.me/${PHONE_NUMBER}?text=${encoded}`, '_blank');
    }

    // ----- FORMAT KES -----
    function formatKES(amount) {
        return amount.toLocaleString('en-KE');
    }

    // ----- CALCULATE DISCOUNTED PRICE -----
    function getDiscountedPrice(price, discount) {
        if (discount && discount > 0) {
            return Math.round(price * (1 - discount / 100));
        }
        return price;
    }

    // ----- TOAST NOTIFICATIONS -----
    function showToast(message, type = 'success') {
        const toast = document.getElementById('toast');
        toast.textContent = message;
        toast.className = 'toast show ' + type;
        setTimeout(() => {
            toast.classList.remove('show');
        }, 3000);
    }

    // ----- UPDATE STATS -----
    function updateStats() {
        document.getElementById('totalProducts').textContent = products.length;
        const inStock = products.filter(p => p.status === 'in-stock').length;
        const outOfStock = products.filter(p => p.status === 'out-of-stock').length;
        document.getElementById('inStockCount').textContent = inStock;
        document.getElementById('outOfStockCount').textContent = outOfStock;
        
        const totalRevenue = products.reduce((sum, p) => sum + (p.sales || 0) * getDiscountedPrice(p.price, p.discount), 0);
        document.getElementById('totalRevenue').textContent = 'KES ' + formatKES(totalRevenue);
        
        const totalSales = products.reduce((sum, p) => sum + (p.sales || 0), 0);
        document.getElementById('totalSales').textContent = totalSales;
    }

    // ----- RENDER PRODUCTS -----
    function renderProducts(filteredProducts) {
        const grid = document.getElementById('productGrid');
        let items = filteredProducts || products;

        const sortBy = document.getElementById('sortFilter').value;
        if (sortBy === 'price-low') {
            items = [...items].sort((a, b) => getDiscountedPrice(a.price, a.discount) - getDiscountedPrice(b.price, b.discount));
        } else if (sortBy === 'price-high') {
            items = [...items].sort((a, b) => getDiscountedPrice(b.price, b.discount) - getDiscountedPrice(a.price, a.discount));
        } else if (sortBy === 'name') {
            items = [...items].sort((a, b) => a.name.localeCompare(b.name));
        } else if (sortBy === 'popular') {
            items = [...items].sort((a, b) => (b.sales || 0) - (a.sales || 0));
        }

        if (items.length === 0) {
            grid.innerHTML = `<div class="empty-state">
                <i class="fas fa-box-open"></i>
                <h3>No software found</h3>
                <p>Add some software using the Manage button above.</p>
            </div>`;
            document.getElementById('resultCount').textContent = 'No results';
            updateStats();
            return;
        }

        const featured = items.filter(p => p.featured);
        const regular = items.filter(p => !p.featured);
        const sortedItems = [...featured, ...regular];

        grid.innerHTML = sortedItems.map(p => {
            const discountedPrice = getDiscountedPrice(p.price, p.discount);
            const hasDiscount = p.discount && p.discount > 0;
            const isInStock = p.status === 'in-stock';
            const alreadyPurchased = hasPurchased(p.id, currentCustomerId);
            
            return `
            <div class="card" data-category="${p.category}" data-id="${p.id}">
                ${p.featured ? `<span class="featured-badge"><i class="fas fa-star"></i> Featured</span>` : ''}
                ${hasDiscount ? `<span class="discount-badge">${p.discount}% OFF</span>` : ''}
                <div class="icon"><i class="${p.icon}"></i></div>
                <span class="category">${p.category}</span>
                <h3>${p.name}</h3>
                <div class="desc">${p.description}</div>
                <div class="specs">
                    <span><i class="fas fa-desktop"></i> ${p.platform ? p.platform.split('/')[0] : 'Multi-platform'}</span>
                    <span><i class="fas fa-memory"></i> ${p.platform ? p.platform.split('/')[1] : '--'}</span>
                    <span><i class="fas fa-tag"></i> ${p.version || 'v1.0'}</span>
                    ${p.sales ? `<span><i class="fas fa-shopping-bag"></i> ${p.sales} sold</span>` : ''}
                </div>
                ${p.fileName ? `<span class="file-tag"><i class="fas fa-file-archive"></i> ${p.fileName} (${p.fileSize || '--'})</span>` : ''}
                <span class="platform-tag"><i class="fas fa-download"></i> ${alreadyPurchased ? 'Already purchased - buy again to download' : 'Buy to download'}</span>
                ${alreadyPurchased ? `<span class="purchased-badge"><i class="fas fa-check-circle"></i> Purchased</span>` : ''}
                <div class="price-row">
                    <span class="price">
                        <span class="kes">KES</span> 
                        ${hasDiscount ? `<span style="text-decoration: line-through; color: #999; font-size: 1.2rem;">${formatKES(p.price)}</span> ` : ''}
                        ${formatKES(discountedPrice)} 
                        <small>${alreadyPurchased ? '(re-download fee)' : 'one-time'}</small>
                    </span>
                    <button class="btn-buy ${!isInStock ? 'out-of-stock' : ''}" 
                            onclick="${isInStock ? `handleBuy(${p.id})` : 'showToast(\'Out of stock\', \'error\')'}"
                            ${!isInStock ? 'disabled' : ''}>
                        ${isInStock ? (alreadyPurchased ? '<i class="fas fa-redo"></i> Buy Again' : '<i class="fas fa-cart-plus"></i> Buy') : 'Out of Stock'}
                    </button>
                </div>
                ${alreadyPurchased ? `<div style="font-size: 0.65rem; color: #ea4335; margin-top: 0.3rem;"><i class="fas fa-exclamation-triangle"></i> One-time download only. Buy again to re-download.</div>` : ''}
                <div style="display: flex; gap: 0.5rem; margin-top: 0.8rem; flex-wrap: wrap;">
                    <button class="btn-secondary" style="padding: 0.3rem 0.8rem; font-size: 0.8rem; display: none;" 
                            onclick="openEditModal(${p.id})" id="editBtn_${p.id}">
                        <i class="fas fa-edit"></i> Edit
                    </button>
                    <button class="btn-danger" style="padding: 0.3rem 0.8rem; font-size: 0.8rem; display: none;" 
                            onclick="openDeleteModal(${p.id})" id="deleteBtn_${p.id}">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                </div>
            </div>
        `}).join('');

        document.getElementById('resultCount').textContent = `Showing ${items.length} products`;
        
        if (isOwner && document.getElementById('adminPanel').classList.contains('show')) {
            showDeleteButtons();
            showEditButtons();
        }
        
        updateStats();
    }

    // ----- HANDLE BUY (Active Button) -----
    function handleBuy(productId) {
        const product = products.find(p => p.id === productId);
        if (!product || product.status === 'out-of-stock') return;

        const discountedPrice = getDiscountedPrice(product.price, product.discount);
        const priceFormatted = formatKES(discountedPrice);
        const alreadyPurchased = hasPurchased(productId, currentCustomerId);
        
        let purchaseMessage = '';
        if (alreadyPurchased) {
            purchaseMessage = `🔄 *RE-PURCHASE*\n\nYou have already purchased this software before.\nThis is a NEW purchase for a fresh download.\n\n`;
        } else {
            purchaseMessage = `🛒 *New Purchase*\n\n`;
        }
        
        const message = purchaseMessage +
                       `📦 Product: *${product.name}*\n` +
                       `💰 Price: *KES ${priceFormatted}*\n` +
                       `📂 Category: ${product.category}\n` +
                       `📌 Version: ${product.version || 'v1.0'}\n` +
                       `📱 Customer ID: ${currentCustomerId}\n\n` +
                       `⚠️ *One-time download only!*\n` +
                       `You must buy again to re-download.\n\n` +
                       `✅ Click "OK" to confirm purchase.`;

        if (confirm(message)) {
            // Record the purchase
            recordPurchase(productId, currentCustomerId);
            
            // Add to cart
            addToCart(productId);
            
            const whatsappMessage = `Hello Audem Kasten Technology's,\n\n` +
                                   `${alreadyPurchased ? '🔄 RE-PURCHASE' : '🛒 NEW PURCHASE'}\n` +
                                   `📦 ${product.name}\n` +
                                   `💰 KES ${priceFormatted}\n` +
                                   `📂 Category: ${product.category}\n` +
                                   `🆔 Customer ID: ${currentCustomerId}\n\n` +
                                   `⚠️ This is a one-time download. Please send the download link.\n` +
                                   `Thank you!`;
            
            contactWhatsApp(whatsappMessage);
            showToast(`✅ ${alreadyPurchased ? 'Re-purchase' : 'Purchase'} confirmed for ${product.name}! Check WhatsApp.`, 'success');
            
            // Re-render to update purchase status
            renderProducts(products);
        }
    }

    // ----- FILTER -----
    function filterProducts() {
        const search = document.getElementById('searchInput').value.toLowerCase();
        const category = document.getElementById('categoryFilter').value;

        const filtered = products.filter(p => {
            const matchesSearch = p.name.toLowerCase().includes(search) || 
                                  p.description.toLowerCase().includes(search);
            const matchesCategory = category === 'all' || p.category === category;
            return matchesSearch && matchesCategory;
        });

        renderProducts(filtered);
    }

    // ----- CART -----
    function addToCart(id) {
        const product = products.find(p => p.id === id);
        if (!product || product.status === 'out-of-stock') return;

        const existing = cart.find(item => item.id === id);
        if (existing) {
            existing.quantity++;
        } else {
            cart.push({ ...product, quantity: 1 });
        }

        updateCart();
    }

    function removeFromCart(id) {
        cart = cart.filter(item => item.id !== id);
        updateCart();
        showToast('🗑️ Item removed from cart');
    }

    function clearCart() {
        if (cart.length === 0) return;
        cart = [];
        updateCart();
        showToast('🗑️ Cart cleared');
    }

    function updateCart() {
        const count = cart.reduce((sum, item) => sum + item.quantity, 0);
        document.getElementById('cartCount').textContent = count;

        const cartItems = document.getElementById('cartItems');
        if (cart.length === 0) {
            cartItems.innerHTML = '<p style="color: #5a6b8a;">Your cart is empty</p>';
            document.getElementById('cartTotal').innerHTML = 'Total: <span class="kes">KES</span> 0';
            return;
        }

        cartItems.innerHTML = cart.map(item => {
            const price = getDiscountedPrice(item.price, item.discount);
            return `
            <div class="cart-item">
                <span>${item.name} (${item.quantity}) 
                    <span class="remove-item" onclick="removeFromCart(${item.id})">&times;</span>
                </span>
                <span>KES ${formatKES(price * item.quantity)}</span>
            </div>
        `}).join('');

        const total = cart.reduce((sum, item) => sum + (getDiscountedPrice(item.price, item.discount) * item.quantity), 0);
        document.getElementById('cartTotal').innerHTML = `Total: <span class="kes">KES</span> ${formatKES(total)}`;
    }

    function toggleCart() {
        document.getElementById('cartSidebar').classList.toggle('show');
        document.getElementById('overlay').classList.toggle('show');
    }

    function checkout() {
        if (cart.length === 0) {
            showToast('Your cart is empty!', 'error');
            return;
        }

        const total = cart.reduce((sum, item) => sum + (getDiscountedPrice(item.price, item.discount) * item.quantity), 0);
        const items = cart.map(item => `${item.name} (${item.quantity})`).join(', ');
        
        let whatsappMessage = `Hello Audem Kasten Technology's,\n\n`;
        whatsappMessage += `🛒 ORDER CHECKOUT\n\n`;
        whatsappMessage += `🆔 Customer ID: ${currentCustomerId}\n\n`;
        whatsappMessage += `📦 Items:\n`;
        cart.forEach(item => {
            const price = getDiscountedPrice(item.price, item.discount);
            const alreadyPurchased = hasPurchased(item.id, currentCustomerId);
            whatsappMessage += `  ${alreadyPurchased ? '🔄' : '📦'} ${item.name} (${item.quantity}) - KES ${formatKES(price * item.quantity)} ${alreadyPurchased ? '(re-purchase)' : ''}\n`;
        });
        whatsappMessage += `\n💰 Total: KES ${formatKES(total)}\n\n`;
        whatsappMessage += `⚠️ One-time downloads only. Each item requires a new purchase for re-download.\n\n`;
        whatsappMessage += `Please send the download links. Thank you!`;
        
        // Record all purchases
        cart.forEach(item => {
            recordPurchase(item.id, currentCustomerId);
        });
        
        contactWhatsApp(whatsappMessage);
        showToast(`✅ Order placed! Total: KES ${formatKES(total)}`, 'success');
        
        cart = [];
        updateCart();
        toggleCart();
        renderProducts(products);
        saveToStorage();
    }

