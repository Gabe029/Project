        } catch (e) {
            console.log('No saved purchases');
        }
    }

    function saveCustomerPurchases() {
        try {
            localStorage.setItem('customerPurchases', JSON.stringify(customerPurchases));
        } catch (e) {
            console.log('Could not save purchases');
        }
    }

    // ----- CHECK IF CUSTOMER HAS PURCHASED A PRODUCT -----
    function hasPurchased(productId, customerId) {
        if (!customerPurchases[productId]) return false;
        return customerPurchases[productId].includes(customerId);
    }

    // ----- RECORD PURCHASE -----
    function recordPurchase(productId, customerId) {
        if (!customerPurchases[productId]) {
            customerPurchases[productId] = [];
        }
        if (!customerPurchases[productId].includes(customerId)) {
            customerPurchases[productId].push(customerId);
            saveCustomerPurchases();
        }
    }

    // ----- GENERATE CUSTOMER ID (uses localStorage or generates new one) -----
    function getCustomerId() {
        let customerId = localStorage.getItem('customerId');
        if (!customerId) {
            customerId = 'CUST-' + Date.now() + '-' + Math.random().toString(36).substr(2, 6);
            localStorage.setItem('customerId', customerId);
        }
        return customerId;
    }

    let cart = [];
    let nextId = 7;
    let deleteTargetId = null;
    let selectedFile = null;
    let editMode = false;
    let editId = null;
    let currentCustomerId = getCustomerId();

    // ----- SCROLL TO TOP -----
    window.addEventListener('scroll', function() {
        const btn = document.getElementById('scrollTopBtn');
        if (window.scrollY > 300) {
            btn.classList.add('show');
        } else {
            btn.classList.remove('show');
        }
    });

    // ----- OWNER AUTHENTICATION -----
    function authenticateOwner() {
        if (isOwner) return true;
        
        const password = prompt('🔐 Enter owner password to manage software:');
        if (password === OWNER_PASSWORD) {
            isOwner = true;
            document.getElementById('adminBtn').classList.add('owner-mode');
            document.getElementById('adminBtn').innerHTML = '<i class="fas fa-cog"></i> Manage (Owner)';
            showToast('✅ Owner authenticated! You can now manage software.', 'success');
            showDeleteButtons();
            showEditButtons();
